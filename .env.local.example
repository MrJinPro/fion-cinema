# TMDb API Configuration
# Получите ваш API ключ на https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Redis URL для серверного кэширования (опционально)
# Если не указан, используется LRU кэш в памяти
REDIS_URL=redis://localhost:6379

# Конфигурация приложения
NEXT_PUBLIC_APP_NAME=ViOn
NEXT_PUBLIC_DEFAULT_LOCALE=ru

# Аналитика (on/off)
# Включите для активации аналитики (требует дополнительной настройки)
NEXT_PUBLIC_ANALYTICS=off

# Для разработки можно указать базовый URL
# NEXT_PUBLIC_BASE_URL=http://localhost:3000